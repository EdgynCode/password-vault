{
  "expo": {
    "name": "Password Vault",
    "slug": "password-manager-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "sdkVersion": "52.0.0",
    "icon": "./assets/vault.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.passwordvault"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "8d1d075d-50f3-41c7-9bfb-64eca388f981"
      }
    },
    "owner": "nht080603",
    "plugins": [
      "expo-localization",
      "expo-secure-store",
      "expo-build-properties",
        {
          "android": {
            "kotlinVersion": "1.9.25"
          }
        }
    ]
  }
}
